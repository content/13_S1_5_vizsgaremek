{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "allowJs": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@studify/types": ["../../packages/types"]
        }
    }
}