{
  "name": "studify",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --prefix-colors blue,magenta --prefix {time}: --timestampFormat HH:mm:ss \"bun run dev --filter apps/ws\" \"bun run dev --filter apps/next\"",
    "migrations:generate": "bun run --filter @studify/database drizzle-kit generate",
    "migrations:push": "bun run --filter @studify/database drizzle-kit push",
    "migrations:drop": "bun run --filter @studify/database drizzle-kit drop",
    "migrations:migrate": "bun run --filter @studify/database drizzle-kit migrate",
    "migrations:seed": "bun ./packages/database/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "concurrently": "^9.1.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "date-fns-tz": "^3.2.0",
    "next": "15.2.2",
    "prettier": "^3.3.3"
  }
}